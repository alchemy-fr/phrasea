{
    "type": "project",
    "license": "proprietary",
    "repositories": [
        {
            "type": "path",
            "url": "../../lib/php/admin-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/configurator-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/test-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/storage-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/auth-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/notify-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/api-test",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/report-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/report-sdk",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/core-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../../lib/php/messenger-bundle",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "alchemy/acl-bundle": "^1.2",
        "api-platform/core": "^3.1",
        "doctrine/common": "^3",
        "doctrine/doctrine-bundle": "^2.9",
        "doctrine/doctrine-migrations-bundle": "^3",
        "doctrine/orm": "^2",
        "fig/link-util": "^1.1",
        "guzzlehttp/guzzle": "^7.2",
        "nelmio/cors-bundle": "^2.1",
        "nyholm/psr7": "^1.1",
        "phpdocumentor/reflection-docblock": "^5.2",
        "predis/predis": "^1.1",
        "ramsey/uuid": "^4.2.3",
        "ramsey/uuid-doctrine": "^1.5",
        "stof/doctrine-extensions-bundle": "^1.7",
        "symfony/amqp-messenger": "^7.4",
        "symfony/asset": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dotenv": "^7.4",
        "symfony/expression-language": "^7.4",
        "symfony/flex": "^2.10",
        "symfony/form": "^7.4",
        "symfony/framework-bundle": "^7.4",
        "symfony/mime": "^7.4",
        "symfony/process": "^7.4",
        "symfony/property-access": "^7.4",
        "symfony/property-info": "^7.4",
        "symfony/psr-http-message-bridge": "^7.4",
        "symfony/runtime": "^7.4",
        "symfony/security-bundle": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/translation": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/validator": "^7.4",
        "symfony/web-link": "^7.4",
        "symfony/yaml": "^7.4",
        "easycorp/easyadmin-bundle": "^5.0.13",
        "php-amqplib/php-amqplib": "^3.7",
        "symfony/ux-twig-component": "^2.36.0",
        "aws/aws-sdk-php": "^3.325",
        "oneup/flysystem-bundle": "^4.4",
        "league/flysystem-aws-s3-v3": "^3.0",
        "lcobucci/jwt": "^5.0",
        "symfony/http-client": "^7",
        "symfony/notifier": "^7.4",
        "opis/json-schema": "^1.0",
        "symfony/string": "^4.0 || ^5 || ^6 || ^7",
        "symfony/monolog-bundle": "^4.0",
        "sentry/sentry-symfony": "^5.10",
        "symfony/novu-notifier": "^7",
        "symfony/messenger": "^7.4",
        "symfony/doctrine-messenger": "^7.4"
    },
    "require-dev": {
        "ext-json": "*",
        "alchemy/api-test": "@dev",
        "alchemy/test-bundle": "*",
        "colinodell/psr-testlogger": "*",
        "friendsofphp/php-cs-fixer": "^3.17",
        "hautelook/alice-bundle": "^2.10",
        "php-parallel-lint/php-var-dump-check": "v0.5",
        "phpstan/phpstan": "^2.1.33",
        "phpunit/phpunit": "^9.5",
        "rector/rector": "^2.3.0",
        "symfony/browser-kit": "^7.4",
        "symfony/css-selector": "^7.4",
        "symfony/debug-bundle": "^7.4",
        "symfony/maker-bundle": "^1.0",
        "symfony/monolog-bundle": "^4.0",
        "symfony/phpunit-bridge": "^7.4",
        "symfony/stopwatch": "^7.4",
        "symfony/var-dumper": "^7.4",
        "symfony/web-profiler-bundle": "^7.4"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "cache-clear": "php -d memory_limit=-1 bin/console cache:clear",
        "auto-scripts": {
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@cache-clear",
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@cache-clear",
            "@auto-scripts"
        ],
        "rector": "vendor/bin/rector",
        "phpstan": "php -d memory_limit=512M vendor/bin/phpstan analyse",
        "cs": "vendor/bin/php-cs-fixer fix",
        "pre-phpunit": [
            "rm -f var/cache/test/data*.db",
            "bin/console -e test doctrine:schema:create"
        ],
        "phpunit": [
            "@pre-phpunit",
            "php -d memory_limit=512M ./bin/phpunit"
        ],
        "test": [
            "vendor/bin/var-dump-check --symfony src",
            "@phpstan",
            "@phpunit"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.4"
        }
    }
}
